---
import Layout from '../layouts/Layout.astro';
import '../styles/events.css';
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import eventPhoto from '../assets/jewlery_event.jpeg';
import bands from '../assets/bands1.jpeg';
import beading1 from '../assets/beading_1.jpeg';
import beading2 from '../assets/beading_2.jpeg';
import beading3 from '../assets/beading_3.jpeg';
import beading4 from '../assets/beading_4.jpeg';
import beading5 from '../assets/beading_5.jpeg';

const beadingShots = [
  { src: beading1, alt: 'Beaded jewellery made at a workshop' },
  { src: beading2, alt: 'Guests choosing beads at a beading workshop' },
  { src: beading3, alt: 'Hands threading beads onto a bracelet' },
  { src: beading4, alt: 'A finished handmade beaded piece' },
  { src: beading5, alt: 'Colourful beads and materials laid out' },
];

const files = import.meta.glob<{ default: ImageMetadata }>('../assets/paintings/*.{jpeg,jpg}', { eager: true });
const heroUrl = (await getImage({ src: files['../assets/paintings/15.jpeg'].default, width: 1920, format: 'webp', quality: 80 })).src;
---
<Layout
  nav="page"
  title="Private Events | Anna's Art Studio"
  description="Hands-on art, craft, and face-painting experiences by Anna Goldmeier for parties, celebrations, and special occasions."
>
  <section class="page-hero">
    <div class="page-hero-bg" style={`background-image:url('${heroUrl}')`}></div>
    <div class="page-hero-inner">
      <h1>Private Events</h1>
      <p>Hands-on art, craft, and face-painting experiences for parties and celebrations.</p>
    </div>
  </section>

  <main class="events-body canvas-texture">
    <section class="ev-intro">
      <div class="ev-intro-img">
        <Image src={eventPhoto} alt="Guests at one of Anna's beading workshops" widths={[500, 900]} sizes="(max-width: 820px) 92vw, 46vw" />
      </div>
      <div class="ev-intro-text">
        <span class="about-title">
          <h2>Creativity brought to your celebration</h2>
          <span class="brush-u">
            <svg viewBox="0 0 300 34" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <defs>
                <filter id="bre" x="-4%" y="-60%" width="108%" height="220%">
                  <feTurbulence type="fractalNoise" baseFrequency="0.7 0.12" numOctaves="2" seed="5" result="n"/>
                  <feDisplacementMap in="SourceGraphic" in2="n" scale="4.5"/>
                </filter>
                <filter id="bredry">
                  <feTurbulence type="fractalNoise" baseFrequency="0.01 0.55" numOctaves="2" seed="9" result="t"/>
                  <feComponentTransfer in="t"><feFuncA type="linear" slope="0.55" intercept="0.62"/></feComponentTransfer>
                </filter>
                <mask id="bremask">
                  <rect width="300" height="34" fill="#fff"/>
                  <rect width="300" height="34" fill="#000" filter="url(#bredry)"/>
                </mask>
              </defs>
              <path filter="url(#bre)" mask="url(#bremask)" fill="currentColor"
                d="M4 18 C 70 9 140 8 168 11 C 226 16 268 12 297 16 C 270 25 210 27 150 24 C 95 22 48 26 4 18 Z"/>
            </svg>
          </span>
        </span>
        <p>Bring a unique creative experience to your next event with personalised art and craft workshops designed to entertain, engage, and inspire guests of all ages. Perfect for private parties, celebrations, and special occasions, each experience can be tailored to suit the atmosphere and style of your event.</p>
        <p>With a vibrant and dynamic approach suited to a wide range of ages, my work is designed to bring personality, creativity, and memorable interaction to every event.</p>
        <div class="ev-jumps">
          <a class="ev-jump" href="#jewellery">
            <Image src={bands} alt="Handcrafted beaded jewellery" widths={[300, 600]} sizes="(max-width: 820px) 46vw, 260px" />
            <span class="ev-jump-body">
              <span class="ev-jump-label">Jewellery</span>
              <span class="ev-jump-sub">Handcrafted beaded pieces</span>
            </span>
            <span class="ev-jump-chev" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </a>
          <a class="ev-jump" href="#beading">
            <Image src={eventPhoto} alt="Guests at a beading workshop" widths={[300, 600]} sizes="(max-width: 820px) 46vw, 260px" />
            <span class="ev-jump-body">
              <span class="ev-jump-label">Beading events</span>
              <span class="ev-jump-sub">Hands-on group workshops</span>
            </span>
            <span class="ev-jump-chev" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </a>
        </div>
      </div>
    </section>

    <section id="beading" class="ev-section">
      <div class="ev-section-head">
        <span class="about-title">
          <h2>Beading events</h2>
          <span class="brush-u">
            <svg viewBox="0 0 300 34" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <defs>
                <filter id="brb" x="-4%" y="-60%" width="108%" height="220%">
                  <feTurbulence type="fractalNoise" baseFrequency="0.7 0.12" numOctaves="2" seed="7" result="n"/>
                  <feDisplacementMap in="SourceGraphic" in2="n" scale="4.5"/>
                </filter>
                <filter id="brbdry">
                  <feTurbulence type="fractalNoise" baseFrequency="0.01 0.55" numOctaves="2" seed="3" result="t"/>
                  <feComponentTransfer in="t"><feFuncA type="linear" slope="0.55" intercept="0.62"/></feComponentTransfer>
                </filter>
                <mask id="brbmask">
                  <rect width="300" height="34" fill="#fff"/>
                  <rect width="300" height="34" fill="#000" filter="url(#brbdry)"/>
                </mask>
              </defs>
              <path filter="url(#brb)" mask="url(#brbmask)" fill="currentColor"
                d="M4 18 C 70 9 140 8 168 11 C 226 16 268 12 297 16 C 270 25 210 27 150 24 C 95 22 48 26 4 18 Z"/>
            </svg>
          </span>
        </span>
      </div>

      <p class="ev-section-lead">Guests can enjoy hands-on beading workshops where they create their own earrings, bracelets, necklaces, keyrings, and personalised accessories using a vibrant variety of beads and materials.</p>

      <div class="ev-scrap">
        {beadingShots.map((shot) => (
          <figure>
            <Image src={shot.src} alt={shot.alt} widths={[300, 600]} sizes="(max-width: 820px) 40vw, 215px" />
          </figure>
        ))}
      </div>

      <div class="ev-section-cta">
        <a class="ev-btn" href="/contact">Enquire about a beading event</a>
      </div>
    </section>

    <div class="ev-head"><h2>The experiences</h2></div>
    <div class="ev-cards">
      <div class="ev-card">
        <h3>Beading workshops</h3>
        <p>Guests can enjoy hands-on beading workshops where they create their own earrings, bracelets, necklaces, keyrings, and personalised accessories using a vibrant variety of beads and materials.</p>
      </div>
      <div class="ev-card">
        <h3>Guided painting</h3>
        <p>Painting sessions are also available, offering the choice of following a step-by-step guided artwork or creatively exploring personal ideas with artistic support and guidance throughout the experience.</p>
      </div>
      <div class="ev-card">
        <h3>Face painting</h3>
        <p>Face painting services can also be included, bringing an additional colourful and playful element to events while adding character, creativity, and memorable entertainment for guests of all ages.</p>
      </div>
    </div>

    <section class="ev-cta">
      <h2>Planning a celebration?</h2>
      <p>For availability, bookings, and personalised event enquiries, please get in touch directly.</p>
      <div class="ev-cta-row">
        <a class="ev-btn" href="/contact">Enquire about an event</a>
        <a class="ev-btn ghost" href="https://wa.me/447910262259">Message on WhatsApp</a>
      </div>
    </section>
  </main>
</Layout>
