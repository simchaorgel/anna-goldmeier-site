---
import Layout from '../layouts/Layout.astro';
import '../styles/events.css';
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import eventPhoto from '../assets/event.jpg';

const beadingAlts = [
  'Beaded jewellery made at a workshop',
  'Guests choosing beads at a beading workshop',
  'Hands threading beads onto a bracelet',
  'A finished handmade beaded piece',
  'Colourful beads and materials laid out',
];
const beadingFiles = import.meta.glob<{ default: ImageMetadata }>('../assets/beading_events/*.{jpeg,jpg}', { eager: true });
const beadingShots = Object.values(beadingFiles).map((m, i) => ({
  src: m.default,
  alt: beadingAlts[i] ?? 'A photo from one of Anna\'s beading workshops',
}));
const beadingBreakAfter = Math.ceil(beadingShots.length / 2);

const files = import.meta.glob<{ default: ImageMetadata }>('../assets/paintings/*.{jpeg,jpg}', { eager: true });
const heroUrl = (await getImage({ src: files['../assets/paintings/15.jpeg'].default, width: 1920, format: 'webp', quality: 80 })).src;
const beadingBgUrl = (await getImage({ src: files['../assets/paintings/19.jpeg'].default, width: 1920, format: 'webp', quality: 80 })).src;
const paintingBgUrl = (await getImage({ src: files['../assets/paintings/23.jpeg'].default, width: 1920, format: 'webp', quality: 80 })).src;
const faceBgUrl = (await getImage({ src: files['../assets/paintings/7.jpeg'].default, width: 1920, format: 'webp', quality: 80 })).src;

const paintingEventFiles = import.meta.glob<{ default: ImageMetadata }>('../assets/painting_events/*.{jpg,jpeg}', { eager: true });
const paintingShots = Object.values(paintingEventFiles).map((m) => ({ src: m.default, alt: "A painting created at one of Anna's easel parties" }));
const paintingBreakAfter = Math.ceil(paintingShots.length / 2);

const faceFiles = import.meta.glob<{ default: ImageMetadata }>('../assets/face_painting_events/*.{jpeg,jpg}', { eager: true });
const faceShots = Object.values(faceFiles).map((m) => ({ src: m.default, alt: "A guest with face paint at one of Anna's events" }));
const faceBreakAfter = Math.ceil(faceShots.length / 2);

const jumps = [
  { href: '#beading', label: 'Beading' },
  { href: '#painting', label: 'Painting' },
  { href: '#face-painting', label: 'Face painting' },
];
---
<Layout
  nav="page"
  title="Private Events | Anna's Art Studio"
  description="Hands-on art, craft, and face-painting experiences by Anna Goldmeier for parties, celebrations, and special occasions."
>
  <div class="ev-top" style={`background-image:url('${heroUrl}')`}>
  <section class="page-hero">
    <div class="page-hero-inner">
      <h1>Private Events</h1>
      <p>Hands-on art, craft, and face-painting experiences for parties and celebrations.</p>
    </div>
  </section>

  <section class="ev-frame">
    <div class="ev-frame-inner canvas-texture">
    <section class="ev-intro">
      <div class="ev-intro-img">
        <Image src={eventPhoto} alt="Guests at one of Anna's beading workshops" widths={[500, 900]} sizes="(max-width: 820px) 92vw, 46vw" />
      </div>
      <div class="ev-intro-text">
        <span class="about-title">
          <h2>Bring creativity to your celebration</h2>
          <span class="brush-u">
            <svg viewBox="0 0 300 34" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <defs>
                <filter id="bre" x="-4%" y="-60%" width="108%" height="220%">
                  <feTurbulence type="fractalNoise" baseFrequency="0.7 0.12" numOctaves="2" seed="5" result="n"/>
                  <feDisplacementMap in="SourceGraphic" in2="n" scale="4.5"/>
                </filter>
                <filter id="bredry">
                  <feTurbulence type="fractalNoise" baseFrequency="0.01 0.55" numOctaves="2" seed="9" result="t"/>
                  <feComponentTransfer in="t"><feFuncA type="linear" slope="0.55" intercept="0.62"/></feComponentTransfer>
                </filter>
                <mask id="bremask">
                  <rect width="300" height="34" fill="#fff"/>
                  <rect width="300" height="34" fill="#000" filter="url(#bredry)"/>
                </mask>
              </defs>
              <path filter="url(#bre)" mask="url(#bremask)" fill="currentColor"
                d="M4 18 C 70 9 140 8 168 11 C 226 16 268 12 297 16 C 270 25 210 27 150 24 C 95 22 48 26 4 18 Z"/>
            </svg>
          </span>
        </span>
        <p>Bring a unique creative experience to your next event with personalised art and craft workshops designed to entertain, engage, and inspire guests of all ages. Perfect for private parties, celebrations, and special occasions, each experience can be tailored to suit the atmosphere and style of your event.</p>
        <p>With a vibrant and dynamic approach suited to a wide range of ages, my work is designed to bring personality, creativity, and memorable interaction to every event.</p>
        <div class="ev-jumps">
          {jumps.map((jump) => (
            <a class="ev-jump" href={jump.href}>{jump.label}</a>
          ))}
        </div>
      </div>
    </section>
    </div>
  </section>
  </div>

  <main class="events-body canvas-texture">
    <section id="beading" class="ev-band" style={`background-image:url('${beadingBgUrl}')`}>
    <div class="ev-frame-inner canvas-texture">
    <div class="ev-section">
      <div class="ev-section-head">
        <span class="about-title">
          <h2>Beading events</h2>
          <span class="brush-u">
            <svg viewBox="0 0 300 34" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <defs>
                <filter id="brb" x="-4%" y="-60%" width="108%" height="220%">
                  <feTurbulence type="fractalNoise" baseFrequency="0.7 0.12" numOctaves="2" seed="7" result="n"/>
                  <feDisplacementMap in="SourceGraphic" in2="n" scale="4.5"/>
                </filter>
                <filter id="brbdry">
                  <feTurbulence type="fractalNoise" baseFrequency="0.01 0.55" numOctaves="2" seed="3" result="t"/>
                  <feComponentTransfer in="t"><feFuncA type="linear" slope="0.55" intercept="0.62"/></feComponentTransfer>
                </filter>
                <mask id="brbmask">
                  <rect width="300" height="34" fill="#fff"/>
                  <rect width="300" height="34" fill="#000" filter="url(#brbdry)"/>
                </mask>
              </defs>
              <path filter="url(#brb)" mask="url(#brbmask)" fill="currentColor"
                d="M4 18 C 70 9 140 8 168 11 C 226 16 268 12 297 16 C 270 25 210 27 150 24 C 95 22 48 26 4 18 Z"/>
            </svg>
          </span>
        </span>
      </div>

      <p class="ev-section-lead">Guests can enjoy hands-on beading workshops where they create their own earrings, bracelets, necklaces, keyrings, and personalised accessories using a vibrant variety of beads and materials. Pricing is £300 for a party of up to 15 guests; for larger groups, please get in touch to discuss your needs in more detail.</p>

      <div class="ev-scrap">
        {beadingShots.map((shot, i) => (
          <>
            <figure>
              <Image src={shot.src} alt={shot.alt} widths={[300, 600]} sizes="(max-width: 820px) 40vw, 215px" />
            </figure>
            {i === beadingBreakAfter - 1 && <span class="ev-scrap-break" aria-hidden="true"></span>}
          </>
        ))}
      </div>

      <div class="ev-section-cta">
        <a class="ev-btn" href="/contact">Enquire about a beading event</a>
      </div>
    </div>
    </div>
    </section>

    <section id="painting" class="ev-band" style={`background-image:url('${paintingBgUrl}')`}>
    <div class="ev-frame-inner canvas-texture">
    <div class="ev-section">
      <div class="ev-section-head">
        <span class="about-title">
          <h2>Painting events</h2>
          <span class="brush-u">
            <svg viewBox="0 0 300 34" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <defs>
                <filter id="brp" x="-4%" y="-60%" width="108%" height="220%">
                  <feTurbulence type="fractalNoise" baseFrequency="0.7 0.12" numOctaves="2" seed="4" result="n"/>
                  <feDisplacementMap in="SourceGraphic" in2="n" scale="4.5"/>
                </filter>
                <filter id="brpdry">
                  <feTurbulence type="fractalNoise" baseFrequency="0.01 0.55" numOctaves="2" seed="6" result="t"/>
                  <feComponentTransfer in="t"><feFuncA type="linear" slope="0.55" intercept="0.62"/></feComponentTransfer>
                </filter>
                <mask id="brpmask">
                  <rect width="300" height="34" fill="#fff"/>
                  <rect width="300" height="34" fill="#000" filter="url(#brpdry)"/>
                </mask>
              </defs>
              <path filter="url(#brp)" mask="url(#brpmask)" fill="currentColor"
                d="M4 18 C 70 9 140 8 168 11 C 226 16 268 12 297 16 C 270 25 210 27 150 24 C 95 22 48 26 4 18 Z"/>
            </svg>
          </span>
        </span>
      </div>

      <p class="ev-section-lead">Painting sessions offer the choice of following a step-by-step guided artwork or freely exploring your own ideas, with artistic support and guidance throughout the experience. Pricing is £250 for a party of up to 10 guests; for larger groups, please get in touch to discuss your needs in more detail.</p>

      <div class="ev-scrap wide">
        {paintingShots.map((shot, i) => (
          <>
            <figure>
              <Image src={shot.src} alt={shot.alt} widths={[360, 720]} sizes="(max-width: 820px) 55vw, 340px" />
            </figure>
            {i === paintingBreakAfter - 1 && <span class="ev-scrap-break" aria-hidden="true"></span>}
          </>
        ))}
      </div>

      <div class="ev-section-cta">
        <a class="ev-btn" href="/contact">Enquire about a painting event</a>
      </div>
    </div>
    </div>
    </section>

    <section id="face-painting" class="ev-band" style={`background-image:url('${faceBgUrl}')`}>
    <div class="ev-frame-inner canvas-texture">
    <div class="ev-section">
      <div class="ev-section-head">
        <span class="about-title">
          <h2>Face painting</h2>
          <span class="brush-u">
            <svg viewBox="0 0 300 34" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <defs>
                <filter id="brf" x="-4%" y="-60%" width="108%" height="220%">
                  <feTurbulence type="fractalNoise" baseFrequency="0.7 0.12" numOctaves="2" seed="2" result="n"/>
                  <feDisplacementMap in="SourceGraphic" in2="n" scale="4.5"/>
                </filter>
                <filter id="brfdry">
                  <feTurbulence type="fractalNoise" baseFrequency="0.01 0.55" numOctaves="2" seed="8" result="t"/>
                  <feComponentTransfer in="t"><feFuncA type="linear" slope="0.55" intercept="0.62"/></feComponentTransfer>
                </filter>
                <mask id="brfmask">
                  <rect width="300" height="34" fill="#fff"/>
                  <rect width="300" height="34" fill="#000" filter="url(#brfdry)"/>
                </mask>
              </defs>
              <path filter="url(#brf)" mask="url(#brfmask)" fill="currentColor"
                d="M4 18 C 70 9 140 8 168 11 C 226 16 268 12 297 16 C 270 25 210 27 150 24 C 95 22 48 26 4 18 Z"/>
            </svg>
          </span>
        </span>
      </div>

      <p class="ev-section-lead">Face painting brings a colourful and playful element to your event, adding character, creativity, and memorable entertainment for guests of all ages. Pricing is £100 for one hour and £150 for two.</p>

      <div class="ev-scrap wide">
        {faceShots.map((shot, i) => (
          <>
            <figure>
              <Image src={shot.src} alt={shot.alt} widths={[360, 720]} sizes="(max-width: 820px) 55vw, 280px" />
            </figure>
            {i === faceBreakAfter - 1 && <span class="ev-scrap-break" aria-hidden="true"></span>}
          </>
        ))}
      </div>

      <div class="ev-section-cta">
        <a class="ev-btn" href="/contact">Enquire about face painting</a>
      </div>
    </div>
    </div>
    </section>

    <section class="ev-cta">
      <h2>Planning a celebration?</h2>
      <p>For availability, bookings, and personalised event enquiries, please get in touch directly.</p>
      <div class="ev-cta-row">
        <a class="ev-btn" href="/contact">Enquire about an event</a>
        <a class="ev-btn ghost" href="https://wa.me/447910262259">Message on WhatsApp</a>
      </div>
    </section>
  </main>
</Layout>
