---
import Layout from '../layouts/Layout.astro';
import '../styles/home.css';
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import annaPhoto from '../assets/anna.jpeg';
import bands from '../assets/bands1.jpeg';
import eventPhoto from '../assets/jewlery_event.jpeg';
import { byFile, heroOrder, selectedOrder } from '../data/paintings.js';

// bulk-import every painting file at once — keys look like '../assets/paintings/19.jpeg'
const paintings = import.meta.glob<{ default: ImageMetadata }>('../assets/paintings/*.jpeg', { eager: true });

// Pull the homepage selections from the shared data (order + titles live in one place).
const selectedWorks = selectedOrder.map((file) => byFile[file]);
const heroData = heroOrder.map((file) => byFile[file]);

// Hero slides — optimized at build time; their URLs are handed to the rotation script below.
const heroSlides = await Promise.all(heroData.map(async (h) => {
  const optimized = await getImage({
    src: paintings[`../assets/paintings/${h.file}`].default,
    width: 1920, format: 'webp', quality: 80,
  });
  return { src: optimized.src, t: h.title, d: h.medium };
}));

// Contact bleed background — also optimized.
const dividerBg = (await getImage({
  src: paintings['../assets/paintings/14.jpeg'].default,
  width: 1920, format: 'webp', quality: 80,
})).src;
---

<Layout nav="hero" title="Anna's Art Studio — Original Paintings, Jewellery & Events">
  	<section class="stage" id="top">
		<div class="bg" id="b0"></div>
		<div class="bg" id="b1"></div>
		<div class="scrim"></div>

		<div class="copy">
			<h1>Anna's Art<br>Studio</h1>
			<p>Original paintings rooted in nature, emotion, and vibrant colour.</p>
			<div class="actions">
				<a class="cta solid" href="/gallery">View the collection</a>
				<a class="cta" href="/gallery">Originals for sale →</a>
			</div>
		</div>

		<div class="caption"><div class="t" id="capT">Poppies, Valley Light</div><div id="capD">Oil on canvas</div></div>
			<a class="down" href="#about">
			Find out more
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
		</a>
  	</section>

  <section class="about canvas-texture" id="about">
    <div class="about-grid">
      <div class="about-img">
        <Image src={annaPhoto} alt="Anna painting in her studio" />
        <div class="credit">Anna in the studio</div>
      </div>
      <div class="about-head">
        <span class="about-title">
          <h2>About the <em>Studio</em></h2>
          <span class="brush-u">
            <svg viewBox="0 0 300 34" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <defs>
                <filter id="bru1" x="-4%" y="-60%" width="108%" height="220%">
                  <feTurbulence type="fractalNoise" baseFrequency="0.7 0.12" numOctaves="2" seed="5" result="n"/>
                  <feDisplacementMap in="SourceGraphic" in2="n" scale="4.5"/>
                </filter>
                <filter id="bru1dry">
                  <feTurbulence type="fractalNoise" baseFrequency="0.01 0.55" numOctaves="2" seed="9" result="t"/>
                  <feComponentTransfer in="t"><feFuncA type="linear" slope="0.55" intercept="0.62"/></feComponentTransfer>
                </filter>
                <mask id="bru1mask">
                  <rect width="300" height="34" fill="#fff"/>
                  <rect width="300" height="34" fill="#000" filter="url(#bru1dry)"/>
                </mask>
              </defs>
              <path filter="url(#bru1)" mask="url(#bru1mask)" fill="currentColor"
                d="M4 18 C 70 9 140 8 168 11 C 226 16 268 12 297 16 C 270 25 210 27 150 24 C 95 22 48 26 4 18 Z"/>
            </svg>
          </span>
        </span>
      </div>
      <div class="about-body">
        <p>Anna's Art Studio presents curated original artwork rooted in expression, emotion, and vibrancy. Inspired by a wide range of artistic movements — particularly Impressionism and illustration — my work reflects decades of dedication to refining technique, style, and creative expression. Through years of exploration and evolving practice, more recently I have developed an artistic approach focused on the beauty to be found within nature, bringing a fresh and organic feeling to everyday life through my art.</p>
        <p>From exclusive original pieces to commissioned works and creative collaborations, each creation is designed to convey emotion, provoke thought, and offer a distinctive visual experience. At the heart of my work is a passion for sharing meaning through art and creating pieces that resonate on a personal and lasting level.</p>
        <div class="sig">— Anna</div>
        <a class="more" href="#">Get in touch →</a>
      </div>
    </div>
  </section>

  <section class="selected">
    <div class="offer-head">
      <span class="about-title">
        <h2>Selected works</h2>
        <span class="brush-u">
          <svg viewBox="0 0 300 34" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <defs>
              <filter id="bru3" x="-4%" y="-60%" width="108%" height="220%">
                <feTurbulence type="fractalNoise" baseFrequency="0.7 0.12" numOctaves="2" seed="5" result="n"/>
                <feDisplacementMap in="SourceGraphic" in2="n" scale="4.5"/>
              </filter>
              <filter id="bru3dry">
                <feTurbulence type="fractalNoise" baseFrequency="0.01 0.55" numOctaves="2" seed="9" result="t"/>
                <feComponentTransfer in="t"><feFuncA type="linear" slope="0.55" intercept="0.62"/></feComponentTransfer>
              </filter>
              <mask id="bru3mask">
                <rect width="300" height="34" fill="#fff"/>
                <rect width="300" height="34" fill="#000" filter="url(#bru3dry)"/>
              </mask>
            </defs>
            <path filter="url(#bru3)" mask="url(#bru3mask)" fill="currentColor"
              d="M4 18 C 70 9 140 8 168 11 C 226 16 268 12 297 16 C 270 25 210 27 150 24 C 95 22 48 26 4 18 Z"/>
          </svg>
        </span>
      </span>
    </div>
   <div class="works">
		{selectedWorks.map((w) => (
			<a class="work" href="#">
				<div class="ph">
					<Image
						src={paintings[`../assets/paintings/${w.file}`].default}
						alt={w.title}
						widths={[400, 760]}
						sizes="(max-width: 560px) 92vw, (max-width: 900px) 46vw, 360px"
					/>
				</div>
				<div class="label"><span class="t">{w.title}</span><span class="m">{w.medium}</span></div>
				</a>
			))}
	</div>
    <div class="sel-cta"><a href="#">View the gallery →</a></div>
  </section>

  <section class="offer">
    <div class="offer-head">
      <span class="about-title">
        <h2>What I offer</h2>
        <span class="brush-u">
          <svg viewBox="0 0 300 34" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <defs>
              <filter id="bru2" x="-4%" y="-60%" width="108%" height="220%">
                <feTurbulence type="fractalNoise" baseFrequency="0.7 0.12" numOctaves="2" seed="5" result="n"/>
                <feDisplacementMap in="SourceGraphic" in2="n" scale="4.5"/>
              </filter>
              <filter id="bru2dry">
                <feTurbulence type="fractalNoise" baseFrequency="0.01 0.55" numOctaves="2" seed="9" result="t"/>
                <feComponentTransfer in="t"><feFuncA type="linear" slope="0.55" intercept="0.62"/></feComponentTransfer>
              </filter>
              <mask id="bru2mask">
                <rect width="300" height="34" fill="#fff"/>
                <rect width="300" height="34" fill="#000" filter="url(#bru2dry)"/>
              </mask>
            </defs>
            <path filter="url(#bru2)" mask="url(#bru2mask)" fill="currentColor"
              d="M4 18 C 70 9 140 8 168 11 C 226 16 268 12 297 16 C 270 25 210 27 150 24 C 95 22 48 26 4 18 Z"/>
          </svg>
        </span>
      </span>
    </div>
    <div class="cards">
      <a class="card" href="#">
        <Image src={paintings['../assets/paintings/18.jpeg'].default} alt="Gallery" widths={[400, 800]} sizes="(max-width: 820px) 92vw, 290px" />
        <div class="cap"><h3>Gallery</h3><span class="desc">Browse Anna's works and order originals or copies</span></div>
      </a>
      <a class="card" href="#">
        <Image src={bands} alt="Jewellery" widths={[400, 800]} sizes="(max-width: 820px) 92vw, 290px" />
        <div class="cap"><h3>Jewellery</h3><span class="desc">Custom made jewellery</span></div>
      </a>
      <a class="card" href="#">
        <Image src={eventPhoto} alt="Private Events" widths={[400, 800]} sizes="(max-width: 820px) 92vw, 290px" />
        <div class="cap"><h3>Private Events</h3><span class="desc">Workshops and parties</span></div>
      </a>
    </div>
  </section>

  <section class="divider" id="contact" style={`background-image:url('${dividerBg}')`}>
    <div class="d">
      <span class="eyebrow">Get in touch</span>
      <h2>Let's create something together.</h2>
      <p>Originals, prints, commissions, jewellery, and private events all begin with a conversation. Feel free to reach out for availability, bookings, or to purchase a piece — I'd love to hear from you.</p>
      <div class="row2">
        <a class="btn-light" href="#">Contact me</a>
        <a class="btn-ghost" href="#">Message on WhatsApp</a>
      </div>
    </div>
  </section>


<script define:vars={{ heroSlides }}>
  window.__heroSlides = heroSlides;
  if (!window.__heroInit) {
    window.__heroInit = true;
    let timer;
    document.addEventListener('astro:before-swap', () => clearInterval(timer));
    document.addEventListener('astro:page-load', () => {
      const b0 = document.getElementById('b0'), b1 = document.getElementById('b1');
      if (!b0 || !b1) return;                       // only on the homepage
      const layers = [b0, b1];
      const capT = document.getElementById('capT'), capD = document.getElementById('capD');
      const slides = window.__heroSlides.slice();
      for (let i = slides.length - 1; i > 0; i--) { const j = (Math.random() * (i + 1)) | 0; [slides[i], slides[j]] = [slides[j], slides[i]]; }
      let cur = 0, active = 0;
      const show = (i) => {
        const next = layers[active ^ 1];
        next.style.backgroundImage = `url('${slides[i].src}')`;
        next.style.animation = 'none'; void next.offsetWidth; next.style.animation = '';
        next.classList.add('show'); layers[active].classList.remove('show');
        active ^= 1;
        if (capT) capT.textContent = slides[i].t;
        if (capD) capD.textContent = slides[i].d;
      };
      show(0);
      clearInterval(timer);
      timer = setInterval(() => { cur = (cur + 1) % slides.length; show(cur); }, 14000);
    });
  }
</script>
</Layout>