---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
const {
  nav = "hero",   // "hero" | "scroll" | "solid"
  title = "Anna's Art Studio",
  description = "Original paintings, fine-art prints, handcrafted jewellery, and creative events by Anna Goldmeier — rooted in nature, emotion, and vibrant colour.",
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,300..500&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <ClientRouter />
</head>

<body data-nav={nav}>
    <!-- Header  -->
    <nav class:list={["nav", { scrolled: nav === "solid" }]}>
        <a class="brand" href="/">Anna's Art Studio</a>
        <div class="links"><a href="/">Home</a><a href="/gallery">Gallery</a><a href="#">Jewellery</a><a href="/private-events">Private Events</a><a href="/contact">Contact</a></div>
        <button class="burger" aria-label="Open menu" aria-expanded="false"><span></span><span></span><span></span></button>
    </nav>

    <!-- Phone menu modal -->
    <div class="menu" id="menu" aria-hidden="true">
        <button class="close" aria-label="Close menu">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
        </button>
        <nav class="menu-links">
            <a href="/">Home</a>
            <a href="/gallery">Gallery</a>
            <a href="#">Jewellery</a>
            <a href="/private-events">Private Events</a>
            <a href="/contact">Contact</a>
        </nav>
    </div>

    <!-- Main content slot  -->
    <slot />

    <!-- Footer -->
    <footer class="site-footer">
        <div class="foot-left">
            <span class="foot-mark">Anna's Art Studio</span>
            <span class="foot-copy">© 2026</span>
        </div>
        <div class="foot-right">
            <a class="foot-btn" href="/gallery">Gallery</a>
            <a class="foot-btn solid" href="/contact">Contact</a>
            <a class="to-top" href="#top">Back to top ↑</a>
        </div>
    </footer>

    <script>
        const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
        const parallax = () => {
            const pbg = (window as any).__pbg;
            if (pbg && !reduceMotion) pbg.style.transform = `translate3d(0, ${window.scrollY * 0.2}px, 0)`;
        };

        // --- global listeners: registered ONCE for the whole session ---
        window.addEventListener('scroll', () => {
            const nav = document.querySelector('.nav');
            if (nav) {
                const mode = document.body.dataset.nav;
                if (mode !== 'solid') {              // solid stays solid (class set in markup)
                    const trigger = mode === 'hero' ? window.innerHeight * 0.7 : 8;
                    nav.classList.toggle('scrolled', window.scrollY > trigger);
                }
            }
            parallax();                              // drifts any .page-hero-bg on the page
        }, { passive: true });

        document.addEventListener('keydown', (e) => {
            if (e.key !== 'Escape') return;
            const menu = document.getElementById('menu');
            if (menu && menu.classList.contains('open')) {
                menu.classList.remove('open');
                document.body.classList.remove('menu-open');
                menu.setAttribute('aria-hidden', 'true');
            }
        });

        // --- per-page setup: runs on first load AND after every view transition ---
        document.addEventListener('astro:page-load', () => {
            // banner parallax target for this page (if any)
            (window as any).__pbg = document.querySelector('.page-hero-bg');
            parallax();
            // nav initial state for this page
            const nav = document.querySelector('.nav');
            if (nav) {
                const mode = document.body.dataset.nav;
                if (mode !== 'solid') {
                    const trigger = mode === 'hero' ? window.innerHeight * 0.7 : 8;
                    nav.classList.toggle('scrolled', window.scrollY > trigger);
                }
            }
            // mobile menu (elements are fresh after each navigation → no stacking)
            const burger = document.querySelector('.burger');
            const menu = document.getElementById('menu');
            if (burger && menu) {
                const setMenu = (open: boolean) => {
                    menu.classList.toggle('open', open);
                    document.body.classList.toggle('menu-open', open);
                    menu.setAttribute('aria-hidden', String(!open));
                    burger.setAttribute('aria-expanded', String(open));
                };
                burger.addEventListener('click', () => setMenu(true));
                menu.addEventListener('click', () => setMenu(false));
            }
        });
    </script>
</body>
</html>