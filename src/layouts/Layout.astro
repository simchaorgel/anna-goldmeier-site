---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
const {
  nav = "hero",   // "hero" | "scroll" | "solid"
  title = "Anna's Art Studio",
  description = "Original paintings, fine-art prints, handcrafted jewellery, and creative events by Anna Goldmeier — rooted in nature, emotion, and vibrant colour.",
  image = "/OG.jpeg",   // social share image (override per page); add public/og.jpeg
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site);
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/jpeg" href="/favicon.jpeg" />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Anna's Art Studio" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Anna Goldmeier",
      "jobTitle": "Artist",
      "url": Astro.site?.toString(),
      "description": description,
    })} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,300..500&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <ClientRouter />
</head>

<body data-nav={nav}>
    <!-- Header  -->
    <nav class:list={["nav", { scrolled: nav === "solid" }]}>
        <a class="brand" href="/">Anna's Art Studio</a>
        <div class="links"><a href="/">Home</a><a href="/gallery">Gallery</a><a href="#">Jewellery</a><a href="/private-events">Private Events</a><a href="/contact">Contact</a></div>
        <button class="burger" aria-label="Open menu" aria-expanded="false"><span></span><span></span><span></span></button>
    </nav>

    <!-- Phone menu modal -->
    <div class="menu" id="menu" aria-hidden="true">
        <button class="close" aria-label="Close menu">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
        </button>
        <nav class="menu-links">
            <a href="/">Home</a>
            <a href="/gallery">Gallery</a>
            <a href="#">Jewellery</a>
            <a href="/private-events">Private Events</a>
            <a href="/contact">Contact</a>
        </nav>
    </div>

    <!-- Main content slot  -->
    <slot />

    <!-- Footer -->
    <footer class="site-footer">
        <div class="foot-left">
            <span class="foot-mark">Anna's Art Studio</span>
            <span class="foot-copy">© 2026</span>
        </div>
        <div class="foot-right">
            <a class="foot-btn" href="/gallery">Gallery</a>
            <a class="foot-btn solid" href="/contact">Contact</a>
            <a class="to-top" href="#top">Back to top ↑</a>
        </div>
    </footer>

    <script>

        // --- nav: 'hero' (homepage) fades transparent→solid; 'page' (content) auto-hides down / reveals up ---
        let lastY = window.scrollY;
        let upAmount = 0;                             // accumulated up-scroll, so a jitter doesn't pop the nav
        const REVEAL_AT = 50;                         // px of deliberate up-scroll before revealing
        const updateNav = () => {
            const nav = document.querySelector('.nav') as HTMLElement | null;
            if (!nav) return;
            const mode = document.body.dataset.nav;
            const y = window.scrollY;
            if (mode === 'hero') {
                nav.classList.toggle('scrolled', y > window.innerHeight * 0.7);
            } else if (mode === 'page') {
                if (y <= 10) {                                             // at top → transparent, in-flow
                    nav.classList.remove('scrolled', 'nav-hidden'); upAmount = 0;
                } else if (y > lastY) {                                    // scrolling down
                    upAmount = 0;
                    // only slide-hide the revealed (fixed) bar; the transparent in-flow bar just scrolls away
                    if (nav.classList.contains('scrolled')) nav.classList.add('nav-hidden');
                } else if (y < lastY) {                                    // scrolling up
                    upAmount += lastY - y;
                    if (upAmount > REVEAL_AT) {
                        if (nav.classList.contains('scrolled')) {
                            nav.classList.remove('nav-hidden');            // already fixed → slide back down
                        } else {
                            // first reveal from the in-flow bar: pin it off-screen, reflow, then slide in
                            nav.classList.add('scrolled', 'nav-hidden');
                            void nav.offsetHeight;
                            nav.classList.remove('nav-hidden');
                        }
                    }
                }
            }
            lastY = y;
        };

        // --- global listeners: registered ONCE for the whole session ---
        window.addEventListener('scroll', () => { updateNav(); }, { passive: true });

        document.addEventListener('keydown', (e) => {
            if (e.key !== 'Escape') return;
            const menu = document.getElementById('menu');
            if (menu && menu.classList.contains('open')) {
                menu.classList.remove('open');
                document.body.classList.remove('menu-open');
                menu.setAttribute('aria-hidden', 'true');
            }
        });

        // --- per-page setup: runs on first load AND after every view transition ---
        document.addEventListener('astro:page-load', () => {
            // nav initial state for this page (never hidden on load)
            lastY = window.scrollY;
            upAmount = 0;
            const nav = document.querySelector('.nav');
            if (nav) {
                const mode = document.body.dataset.nav;
                nav.classList.remove('nav-hidden');
                if (mode === 'hero') nav.classList.toggle('scrolled', window.scrollY > window.innerHeight * 0.7);
                else if (mode === 'page') nav.classList.toggle('scrolled', window.scrollY > 10);
            }
            // mobile menu (elements are fresh after each navigation → no stacking)
            const burger = document.querySelector('.burger');
            const menu = document.getElementById('menu');
            if (burger && menu) {
                const setMenu = (open: boolean) => {
                    menu.classList.toggle('open', open);
                    document.body.classList.toggle('menu-open', open);
                    menu.setAttribute('aria-hidden', String(!open));
                    burger.setAttribute('aria-expanded', String(open));
                };
                burger.addEventListener('click', () => setMenu(true));
                menu.addEventListener('click', () => setMenu(false));
            }
        });
    </script>
</body>
</html>